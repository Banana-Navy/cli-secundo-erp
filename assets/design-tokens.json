        "padding-x": { "$value": "{primitive.spacing.4}", "$type": "dimension" },
        "padding-y": { "$value": "{primitive.spacing.2}", "$type": "dimension" },
        "font-size": { "$value": "{primitive.fontSize.base}", "$type": "dimension" }
      },
      "secondary": {
        "bg": { "$value": "{semantic.color.secondary}", "$type": "color" },
        "fg": { "$value": "{semantic.color.secondary-foreground}", "$type": "color" }
