        "foreground": { "$value": "{primitive.color.stone.50}", "$type": "color" },
        "primary-foreground": { "$value": "{primitive.color.stone.900}", "$type": "color" },
        "secondary": { "$value": "{primitive.color.stone.800}", "$type": "color" },
